# Sylveste monorepo .gitignore
# Each subproject has its own .git — ignore them all here.
# Only the monorepo skeleton, beads, and shared docs are tracked.

# ── Subproject directories (each has its own repo) ──
apps/
os/
core/
interverse/
sdk/*

# ── Beads runtime artifacts (beads' own .gitignore handles the rest) ──
.beads/bd.sock.startlock
.beads/daemon-error

# ── Claude Code session artifacts ──
.claude/settings.local.json
.claude/*.log
.claude/worktrees/

# ── Flux agent registry ──
# Generated agents are gitignored by default. Promoted agents (used/proven)
# are force-added with `git add -f`. The index is always a rebuildable cache.
.claude/agents/fd-*.md
.claude/agents/.index.yaml
# Flux-gen spec files (generated per-review, not tracked)
.claude/flux-gen-specs/

# ── Local tool caches ──
.tmp/

# ── Interfluence local learnings log ──
.interfluence/learnings-raw.log

# ── Stale symlinks ──
docs/docs

# ── Clavain ephemeral data ──
.clavain/scratch/
.clavain/verdicts/
.clavain/quality-gates/
.clavain/reviews/
.clavain/checkpoint.json
.clavain/routing-decisions.jsonl
.clavain/intercore.db
.clavain/intercore.db.backup-*
.clavain/interspect/

# bv (beads viewer) local config and caches
.bv/

# ── Interwatch drift state (runtime, not committed) ──
# watchables.yaml is tracked (project config); drift/history state is not
.interwatch/*
!.interwatch/watchables.yaml

# ── Intermem state (per-project, not committed) ──
.intermem/

# ── interlore scan state (per-project, not committed) ──
.interlore/

# ── Generated secret scan artifacts (reports/logs) ──
docs/reports/security/secret-scan-backfill-*/
docs/reports/security/secret-scan-backfill-*.md

# ── Nested repos (own remotes, not submodules) ──
masaq/

# ── Research clones (not part of monorepo) ──
research/*
!research/AGENTS.md
!research/REPO_INDEX.md
docs/research/*/
!docs/research/dialectics/
!docs/research/flux-drive/
!docs/research/flux-research/

# Dolt database files (added by bd init)
.dolt/
*.db
.interkasten.yaml

# Beads / Dolt files (added by bd init)
.beads-credential-key
.beads/dolt/

# Per-machine tool state (added 2026-04-19)
.beads/remote/
.claude/projects/
.claude/scheduled_tasks.lock
.clavain/cxdb/
.clavain/intercept/
.codex
data/
