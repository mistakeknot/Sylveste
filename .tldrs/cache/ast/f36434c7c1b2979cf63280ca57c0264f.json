out due to failed attempts","is_method":true,"is_async":false,"decorators":[],"line_number":126,"language":"python"},{"name":"approve_code","params":["self","platform: str","code: str"],"return_type":"Optional[dict]","docstring":"Approve a pairing code. Adds the user to the approved list.\n\nReturns {user_id, user_name} on success, None if code is invalid/expired.","is_method":true,"is_async":false,"decorators":[],"line_number":168,"language":"python"},{"name":"list_pending","params":["self","platform: str = None"],"return_type":"list","docstring":"List pending pairing requests, optionally filtered by platform.","is_method":true,"is_async":false,"decorators":[],"line_number":193,"language":"python"},{"name":"clear_pending","params":["self","platform: str = None"],"return_type":"int","docstring":"Clear all pending requests. Returns count removed.","is_method":true,"is_async":false,"decorators":[],"line_number":211,"language":"python"},{"name":"_is_rate_limited","params":["self","platform: str","user_id: str"],"return_type":"bool","docstring":"Check if a user has requested a code too recently.","is_method":true,"is_async":false,"decorators":[],"line_number":223,"language":"python"},{"name":"_record_rate_limit","params":["self","platform: str","user_id: str"],"return_type":"None","docstring":"Record the time of a pairing request for rate limiting.","is_method":true,"is_async":false,"decorators":[],"line_number":230,"language":"python"},{"name":"_is_locked_out","params":["self","platform: str"],"return_type":"bool","docstring":"Check if a platform is in lockout due to failed approval attempts.","is_method":true,"is_async":false,"decorators":[],"line_number":237,"language":"python"},{"name":"_record_failed_attempt","params":["self","platform: str"],"return_type":"None","docstring":"Record a failed approval attempt. Triggers lockout after MAX_FAILED_ATTEMPTS.","is_method":true,"is_async":false,"decorators":[],"line_number":244,"language":"python"},{"name":"_cleanup_expire