{"mtime_ns":1772473803545748700,"size":10375,"module_info":{"file_path":"/home/mk/projects/Demarch/research/hermes_agent/gateway/pairing.py","language":"python","docstring":"DM Pairing System\n\nCode-based approval flow for authorizing new users on messaging platforms.\nInstead of static allowlists with user IDs, unknown users receive a one-time\npairing code that the bot owner approves via the CLI.\n\nSecurity features (based on OWASP + NIST SP 800-63-4 guidance):\n  - 8-char codes from 32-char unambiguous alphabet (no 0/O/1/I)\n  - Cryptographic randomness via secrets.choice()\n  - 1-hour code expiry\n  - Max 3 pending codes per platform\n  - Rate limiting: 1 request per user per 10 minutes\n  - Lockout after 5 failed approval attempts (1 hour)\n  - File permissions: chmod 0600 on all data files\n  - Codes are never logged to stdout\n\nStorage: ~/.hermes/pairing/","imports":[{"module":"json","names":[],"is_from":false,"line_number":21},{"module":"os","names":[],"is_from":false,"line_number":22},{"module":"secrets","names":[],"is_from":false,"line_number":23},{"module":"time","names":[],"is_from":false,"line_number":24},{"module":"pathlib","names":["Path"],"is_from":true,"line_number":25},{"module":"typing","names":["Optional"],"is_from":true,"line_number":26}],"classes":[{"name":"PairingStore","bases":[],"docstring":"Manages pairing codes and approved user lists.\n\nData files per platform:\n  - {platform}-pending.json   : pending pairing requests\n  - {platform}-approved.json  : approved (paired) users\n  - _rate_limits.json         : rate limit tracking","methods":[{"name":"__init__","params":["self"],"return_type":null,"docstring":null,"is_method":true,"is_async":false,"decorators":[],"line_number":65,"language":"python"},{"name":"_pending_path","params":["self","platform: str"],"return_type":"Path","docstring":null,"is_method":true,"is_async":false,"decorators":[],"line_number":68,"language":"python"},{"name":"_approved_path","params":["self","platform: str"],