ain","params":[],"return_type":"small=1, main=4\n        let mut cache = S3FifoCache::new(5);\n        cache.insert(\"a\", 10);\n        cache.get(&\"a\"); // bump freq\n        cache.insert(\"b\", 20); // evicts \"a\" to main\n        assert_eq!(cache.main_len(), 1);\n\n        assert_eq!(cache.remove(&\"a\"), Some(10));\n        assert_eq!(cache.main_len(), 0);\n    }","docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":550,"language":"rust"},{"name":"s3fifo_remove_from_ghost_returns_none","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":563,"language":"rust"},{"name":"s3fifo_clear","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":575,"language":"rust"},{"name":"s3fifo_capacity_returns_total","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":589,"language":"rust"},{"name":"s3fifo_capacity_minimum_one_small","params":[],"return_type":"small=1 (max of 5/10=0 and 1)\n        let cache: S3FifoCache<&str, i32> = S3FifoCache::new(5);\n        assert_eq!(cache.small_capacity, 1);\n        assert_eq!(cache.main_capacity, 4);\n        assert_eq!(cache.capacity(), 5);\n    }","docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":595,"language":"rust"},{"name":"s3fifo_insert_updates_existing_in_small","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":604,"language":"rust"},{"name":"s3fifo_insert_updates_existing_in_main","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":613,"language":"rust"},{"name":"s3fifo_freq_saturates_at_3","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":625,"language":"rust"},{"name":"s3fifo_zero_capacity_panics","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":638,"language":"rust"},{"name":"s3fifo_get_mut_in_main","params":[],"return_type":null,"docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":643,"language":"rust"},{"name":"s3fifo_capacity_one","params":[],"return_type":"small=1, main=0\n        let mut cache = S3FifoCache::new(1);\n        assert_eq!(cache.small_capacity, 1);\n        assert_eq!(cache.main_capacity, 0);\n        assert_eq!(cache.capacity(), 1);\n\n        cache.insert(\"a\", 1);\n        assert_eq!(cache.get(&\"a\"), Some(&1));\n        assert_eq!(cache.len(), 1);\n\n        // Inserting \"b\" evicts \"a\" from small. Since freq=1, \"a\" attempts\n        // promotion to main (cap=0), which may cause len to temporarily\n        // exceed 1. This is a known edge case with capacity=1.\n        cache.insert(\"b\", 2);\n        assert_eq!(cache.get(&\"b\"), Some(&2));\n        // \"a\" may be in main (promoted) or evicted, depending on budget loop\n        assert!(!cache.is_empty());\n    }","docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":658,"language":"rust"},{"name":"s3fifo_capacity_two","params":[],"return_type":"small=1, main=1\n        let mut cache = S3FifoCache::new(2);\n        assert_eq!(cache.small_capacity, 1);\n        assert_eq!(cache.main_capacity, 1);\n\n        cache.insert(\"a\", 1);\n        cache.get(&\"a\"); // bump freq so it promotes to main\n        cache.insert(\"b\", 2); // evicts \"a\" from small \u2192 promotes to main\n        assert_eq!(cache.main_len(), 1);\n        assert_eq!(cache.small_len(), 1);\n        assert_eq!(cache.get(&\"a\"), Some(&1));\n        assert_eq!(cache.get(&\"b\"), Some(&2));\n    }","docstring":null,"is_method":false,"is_async":false,"decorators":[],"line_number":679,"language":"rust"},{"name":"s3fifo_len_invariant_through_operations","params":[],"return_type":null,"docstring":null,"i